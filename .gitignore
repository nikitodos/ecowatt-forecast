# EcoWatt – .gitignore
# -----------------------------------------------------------------------

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# -----------------------------------------------------------------------
# ML artefacts  (large binary files – do NOT commit trained models)
# -----------------------------------------------------------------------
*.xgb
*.pkl
*.model
*.bin
*.h5
*.pt
*.onnx
*.joblib

# Metadata files generated during training (optional to commit)
metadata_*.json

# -----------------------------------------------------------------------
# Runtime outputs – also typically not committed
# -----------------------------------------------------------------------
output/
MeteoWatt_TEMP/
*.cache*
.cache/
.cache.sqlite

# -----------------------------------------------------------------------
# Credentials / secrets  (NEVER commit these)
# -----------------------------------------------------------------------
.env
.env.*
secrets.json
credentials.json
config_local.py
config_prod.py

# -----------------------------------------------------------------------
# Notebook checkpoints
# -----------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------
# OS / IDE
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------
*.log
logs/
